{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "next_instruction", "status", "commit_message"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "next_instruction": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["continue", "pivot", "done"]
    },
    "commit_message": {
      "type": "string",
      "minLength": 1
    }
  }
}
